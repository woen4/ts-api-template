generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-1.1.x"]
  previewFeatures = ["omitApi", "strictUndefinedChecks"]
}

datasource db {
  provider = "postgresql"
}

// -- Usuários --

model User {
  id   String @id @default(uuid())
  name String

  @@map("users")
}

// -- Sistema Multitenant --

model Company {
  id       String @id @default(uuid())
  name     String
  cnpj     String @unique
  planTier String @map("plan_tier")

  erpConfigs       CompanyErpConfig[]
  bankTransactions BankTransaction[]

  @@map("companies")
}

// -- Catálogo de Destinos (Output / ERPs) --

model ErpProvider {
  id         Int    @id @default(autoincrement())
  name       String
  slug       String @unique
  apiVersion String @map("api_version")

  companyErpConfigs CompanyErpConfig[]
  syncLogs          ErpSyncLog[]

  @@map("erp_providers")
}

model CompanyErpConfig {
  id             String @id @default(uuid())
  companyId      String @map("company_id")
  erpProviderId  Int    @map("erp_provider_id")
  externalApiKey String @map("external_api_key")
  endpointUrl    String @map("endpoint_url")
  settings       Json

  company     Company     @relation(fields: [companyId], references: [id])
  erpProvider ErpProvider @relation(fields: [erpProviderId], references: [id])

  @@map("company_erp_configs")
}

// -- Dados Financeiros --

model BankTransaction {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  externalId  String   @unique @map("external_id")
  description String
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime @db.Date
  rawJson     Json     @map("raw_json")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("bank_transactions")
}

// -- Pivot de Sincronização Agnóstica (A ponte para os ERPs) --

model ErpSyncLog {
  id            String    @id @default(uuid())
  erpProviderId Int       @map("erp_provider_id")
  referenceId   String    @map("reference_id")
  referenceType String    @map("reference_type")
  syncStatus    String    @map("sync_status")
  erpResponse   String?   @map("erp_response")
  syncedAt      DateTime? @map("synced_at")

  erpProvider ErpProvider @relation(fields: [erpProviderId], references: [id])

  @@map("erp_sync_logs")
}
